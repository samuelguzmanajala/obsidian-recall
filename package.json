{
  "name": "obsidian-recall",
  "version": "0.1.0",
  "description": "Modern spaced repetition plugin for Obsidian, powered by FSRS",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --watch",
    "build": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --minify",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": ["obsidian", "spaced-repetition", "fsrs", "flashcards"],
  "author": "Samuel Guzman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samuelguzmanajala/obsidian-recall.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ts-fsrs": "^4.0.0"
  }
}
