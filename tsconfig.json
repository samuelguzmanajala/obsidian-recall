{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@context/*": ["context/src/*"],
      "@backend/*": ["app/backend/src/*"],
      "@frontend/*": ["app/frontend/src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["context/**/*.ts", "app/**/*.ts", "main.ts"],
  "exclude": ["node_modules", "dist"]
}
